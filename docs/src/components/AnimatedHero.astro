---
const phrases = [
  { text: "Deploys in ~6 seconds", color: "#f97316" },
  { text: "API, database, queues — one deploy", color: "#a78bfa" },
  { text: "No YAML. No state files. No bootstrapping.", color: "#f472b6" },
  { text: "Export. Deploy. Done.", color: "#38bdf8" },
];
---

<div class="animated-hero">
  <h1>
    <span class="title">Effortless AWS</span>
    <span class="rotating-wrapper">
      {phrases.map((phrase, i) => (
        <span class="rotating-text" style={`--i: ${i}; color: ${phrase.color};`}>
          {phrase.text}
        </span>
      ))}
    </span>
  </h1>
  <p class="tagline">The fastest way to ship a TypeScript app onto AWS.</p>
  <div class="hero-actions">
    <a class="cta" href="/installation/">Getting Started →</a>
    <a class="cta-ghost" href="https://github.com/kondaurovDev/effortless-aws" target="_blank" rel="noopener">GitHub →</a>
  </div>
</div>

<style>
  .animated-hero {
    text-align: center;
    padding: 2rem 1rem 1.25rem;
    max-width: 48rem;
    margin: 0 auto;
  }

  .animated-hero h1 {
    margin: 0;
  }

  .title {
    display: block;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--sl-color-white);
    margin-bottom: 0.5rem;
  }

  .rotating-wrapper {
    display: block;
    position: relative;
    height: 1.5em;
    overflow: hidden;
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-weight: 700;
    line-height: 1.5;
  }

  .rotating-text {
    display: block;
    position: absolute;
    width: 100%;
    left: 0;
    opacity: 0;
    transform: translateY(30px);
    animation: rotate-text 8s ease-in-out infinite;
    animation-delay: calc(var(--i) * 2s);
  }

  .tagline {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    color: var(--sl-color-gray-3);
    margin: 0.85rem 0 1.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta {
    display: inline-block;
    padding: 0.65rem 1.3rem;
    background: var(--sl-color-accent);
    color: white !important;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .cta-ghost {
    display: inline-block;
    padding: 0.65rem 1.1rem;
    color: var(--sl-color-white) !important;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .cta-ghost:hover {
    border-color: var(--sl-color-gray-3);
    transform: translateY(-1px);
  }

  @keyframes rotate-text {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    5% {
      opacity: 1;
      transform: translateY(0);
    }
    20% {
      opacity: 1;
      transform: translateY(0);
    }
    25% {
      opacity: 0;
      transform: translateY(-30px);
    }
    100% {
      opacity: 0;
      transform: translateY(-30px);
    }
  }
</style>
